{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "remote-overlay",
  "description": "Grant the GitHub Pages overlay page (remote origin) the few window controls it needs: drag to move, and close.",
  "windows": ["main"],
  "remote": {
    "urls": ["https://indiegames.design/*"]
  },
  "permissions": [
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:event:default"
  ]
}
